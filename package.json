{
  "name": "svachmic-cz",
  "version": "2026.02.18",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Monorepo for svachmic.cz sites",
  "scripts": {
    "build": "turbo run build",
    "dev:blog-dev": "turbo run develop --filter=svachmic-cz-dev-blog",
    "dev:blog-personal": "turbo run develop --filter=svachmic-cz-blog",
    "dev:homepage": "turbo run develop --filter=svachmic-homepage",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.5.0"
  }
}
