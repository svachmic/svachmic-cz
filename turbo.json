{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["public/**"]
    },
    "develop": {
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "format": {
      "cache": false
    }
  }
}
